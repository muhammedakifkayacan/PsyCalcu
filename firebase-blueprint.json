{
  "entities": {
    "User": {
      "title": "User",
      "description": "User settings and details",
      "type": "object",
      "properties": {
        "settings": {
          "type": "object",
          "description": "User application settings"
        },
        "sessions": {
          "type": "array",
          "description": "User sessions array"
        }
      }
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Global admin announcements for all users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "author": { "type": "string" }
      },
      "required": ["id", "title", "message", "type", "createdAt"]
    },
    "Registration": {
      "title": "Registration",
      "description": "Therapist registration request and feature flags",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "status": { "type": "string", "enum": ["approved", "pending", "rejected", "legacy_active"] },
        "createdAt": { "type": "string" },
        "maxSessionsLimit": { "type": "integer" },
        "featuresAIAllowed": { "type": "boolean" },
        "featuresExportAllowed": { "type": "boolean" },
        "featuresCalendarAllowed": { "type": "boolean" },
        "featuresAccountingAllowed": { "type": "boolean" },
        "featuresDebtTrackerAllowed": { "type": "boolean" },
        "featuresSmartPriceMatchingAllowed": { "type": "boolean" },
        "adminNote": { "type": "string" }
      },
      "required": ["userId", "email", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores therapist settings and local sessions backup"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global administrator notifications and system-wide announcements"
    },
    "/registrations/{userId}": {
      "schema": "Registration",
      "description": "User registration documents containing membership statuses and granular feature flags."
    }
  }
}
